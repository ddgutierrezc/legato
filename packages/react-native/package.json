{
  "name": "@ddgutierrezc/legato-react-native",
  "version": "0.1.0",
  "description": "Expo Modules binding package for Legato host apps.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:host": "node ./scripts/validate-dev-build-host.mjs",
    "evidence:phase4.1": "node ./scripts/phase4-1-dev-build-parity-evidence.mjs",
    "evidence:phase4.2": "node ./scripts/phase4-2-dev-build-evidence-contract.mjs",
    "readiness:phase4.3": "node ./scripts/phase4-3-release-readiness-gate.mjs",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "generate:mocks": "npx expo-modules-test-core generate-ts-mocks --module-name Legato --output mocks/LegatoModule.ts"
  },
  "keywords": [
    "legato",
    "expo",
    "expo-module",
    "react-native",
    "audio",
    "autolinking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ddgutierrezc/legato.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/ddgutierrezc/legato/issues"
  },
  "author": "Legato",
  "license": "MIT",
  "homepage": "https://github.com/ddgutierrezc/legato/tree/main/packages/react-native#readme",
  "exports": {
    ".": "./build/index.js"
  },
  "expo": {
    "plugin": "./app.plugin.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "app.plugin.js",
    "ios/LegatoModule.swift",
    "legato-react-native.podspec",
    "android/src",
    "android/build.gradle",
    "android/gradle.properties",
    "android/settings.gradle",
    "expo-module.config.json",
    "README.md"
  ],
  "dependencies": {
    "@ddgutierrezc/legato-contract": "^1.1.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.1",
    "jest-expo": "^55.0.13",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.18",
    "react-native": "0.82.1"
  },
  "peerDependencies": {
    "@ddgutierrezc/legato-contract": "^1.1.0",
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "jest-expo",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/"
    ]
  }
}
