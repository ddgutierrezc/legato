{
  "name": "@legato/capacitor",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor binding MVP for Legato.",
  "author": "Legato",
  "homepage": "https://github.com/legato/legato",
  "repository": {
    "type": "git",
    "url": "https://github.com/legato/legato.git",
    "directory": "packages/capacitor"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "legato": "./src/cli/index.mjs"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "android",
    "ios",
    "Package.swift",
    "README.md",
    "CapacitorLegato.podspec"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0",
    "@legato/contract": "^0.1.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "@legato/contract": "file:../contract",
    "typescript": "^5.6.3"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
