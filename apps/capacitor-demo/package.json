{
  "name": "@legato/capacitor-demo",
  "version": "0.1.1",
  "private": true,
  "description": "Minimal Capacitor demo app for @ddgutierrezc/legato-capacitor integration.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "smoke:prep": "npm run build && npm run cap:sync",
    "collect:native:android-resolution": "./android/gradlew :app:dependencies --configuration debugCompileClasspath > ./artifacts/android-dependency-resolution.log",
    "collect:native:ios-resolution": "xcodebuild -resolvePackageDependencies -project ./ios/App/App.xcodeproj > ./artifacts/ios-spm-resolution.log",
    "collect:smoke:android": "node ./scripts/collect-android-smoke.mjs --output ./artifacts/android-smoke-report.json",
    "collect:smoke:ios": "node ./scripts/collect-ios-smoke.mjs --output ./artifacts/ios-smoke-report.json",
    "validate:native:artifacts": "node ./scripts/validate-native-artifacts.mjs --plugin-gradle ../../packages/capacitor/android/build.gradle --native-artifacts-contract ../../packages/capacitor/native-artifacts.json --android-settings ./android/settings.gradle --capapp-spm-package ./ios/App/CapApp-SPM/Package.swift --plugin-swift-package ../../packages/capacitor/Package.swift --plugin-swift-source ../../packages/capacitor/ios/Sources/LegatoPlugin/LegatoPlugin.swift --capacitor-config ./ios/App/App/capacitor.config.json",
    "validate:external:consumer": "node ./scripts/run-external-consumer-validation.mjs",
    "validate:npm:readiness": "node ./scripts/run-npm-readiness.mjs",
    "release:npm:policy": "node ./scripts/run-npm-release-policy.mjs",
    "release:npm:execute": "node ./scripts/release-npm-execution.mjs",
    "test:npm:readiness": "node --test ./scripts/run-external-consumer-validation.test.mjs ./scripts/npm-release-readiness-workflow.test.mjs ./scripts/npm-tech-preview-checklist-docs.test.mjs",
    "release:control:contract:check": "node ./scripts/release-control-contract.mjs",
    "release:control:summary:aggregate": "node ./scripts/aggregate-release-summary.mjs",
    "capture:release:native-artifacts": "node ./scripts/capture-native-release-evidence.mjs --output-dir ./artifacts/release-native-artifact-foundation-v1",
    "validate:release:native-artifacts": "node ./scripts/validate-native-release-gate.mjs --plugin-gradle ../../packages/capacitor/android/build.gradle --native-artifacts-contract ../../packages/capacitor/native-artifacts.json --android-settings ./android/settings.gradle --capapp-spm-package ./ios/App/CapApp-SPM/Package.swift --plugin-swift-package ../../packages/capacitor/Package.swift --plugin-swift-source ../../packages/capacitor/ios/Sources/LegatoPlugin/LegatoPlugin.swift --capacitor-config ./ios/App/App/capacitor.config.json --evidence-manifest ./artifacts/release-native-artifact-foundation-v1/manifest.json",
    "validate:smoke:android": "node ./scripts/validate-smoke-report.mjs --report ./artifacts/android-smoke-report.json",
    "validate:smoke:ios": "node ./scripts/validate-smoke-report.mjs --report ./artifacts/ios-smoke-report.json",
    "validate:smoke:all": "node ./scripts/validate-smoke-report.mjs --report ./artifacts/android-smoke-report.json --report ./artifacts/ios-smoke-report.json",
    "release:android:preflight": "node ../../native/android/core/scripts/release-android.mjs preflight --contract ../../packages/capacitor/native-artifacts.json --build-gradle ../../native/android/core/build.gradle --project-dir ../../native/android/core",
    "release:android:publish": "node ../../native/android/core/scripts/release-android.mjs publish --contract ../../packages/capacitor/native-artifacts.json --build-gradle ../../native/android/core/build.gradle --project-dir ../../native/android/core",
    "release:android:verify": "node ../../native/android/core/scripts/release-android.mjs verify --contract ../../packages/capacitor/native-artifacts.json",
    "release:android:verify:ci": "node ./scripts/retry-android-release-verify.mjs",
    "release:scope:check": "node ./scripts/check-publication-scope.mjs --repo-root ../..",
    "release:ios:preflight": "node ../../packages/capacitor/scripts/release-ios-preflight.mjs --contract ../../packages/capacitor/native-artifacts.json --native-package ../../native/ios/LegatoCore/Package.swift --plugin-package ../../packages/capacitor/Package.swift --release-tag ${IOS_RELEASE_TAG:-v0.1.1} --json-out ./artifacts/ios-publication-v1/${IOS_RELEASE_ID:-manual}/preflight.json",
    "release:ios:publish": "node ./scripts/release-ios-execution.mjs publish --release-id ${IOS_RELEASE_ID:-manual} --artifacts-dir ./artifacts/ios-publication-v2 --release-tag ${IOS_RELEASE_TAG:-v0.1.1} --distribution-repo ${IOS_DISTRIBUTION_REPO:?set IOS_DISTRIBUTION_REPO} --distribution-ref ${IOS_DISTRIBUTION_REF:-main} --github-app-token ${IOS_GITHUB_APP_TOKEN:?set IOS_GITHUB_APP_TOKEN}",
    "release:ios:handoff": "node ./scripts/release-ios-execution.mjs handoff --release-id ${IOS_RELEASE_ID:-manual} --artifacts-dir ./artifacts/ios-publication-v1 --release-tag ${IOS_RELEASE_TAG:-v0.1.1} --external-repo ${IOS_EXTERNAL_REPO:?set IOS_EXTERNAL_REPO} --external-tag ${IOS_EXTERNAL_TAG:?set IOS_EXTERNAL_TAG} --proof-type ${IOS_PROOF_TYPE:?set IOS_PROOF_TYPE} --proof-value ${IOS_PROOF_VALUE:?set IOS_PROOF_VALUE} --operator ${IOS_OPERATOR:?set IOS_OPERATOR} --published-at ${IOS_PUBLISHED_AT:?set IOS_PUBLISHED_AT}",
    "release:ios:verify": "node ./scripts/release-ios-execution.mjs verify --release-id ${IOS_RELEASE_ID:-manual} --artifacts-dir ./artifacts/ios-publication-v1 --attempts ${IOS_VERIFY_ATTEMPTS:-6} --backoff-ms ${IOS_VERIFY_BACKOFF_MS:-120000}",
    "release:ios:closeout": "node ./scripts/release-ios-execution.mjs closeout --release-id ${IOS_RELEASE_ID:-manual} --artifacts-dir ./artifacts/ios-publication-v1",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@ddgutierrezc/legato-capacitor": "file:../../packages/capacitor",
    "@ddgutierrezc/legato-contract": "file:../../packages/contract"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
