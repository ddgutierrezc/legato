{
  "name": "@legato/capacitor-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Capacitor demo app for @legato/capacitor integration.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "smoke:prep": "npm run build && npm run cap:sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@legato/capacitor": "file:../../packages/capacitor",
    "@legato/contract": "file:../../packages/contract"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
